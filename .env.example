# 复制为项目根 .env（docker compose 读取）
APP_PORT=8080
INFERENCE_DEVICE=cpu
CORS_ORIGINS=http://localhost:8080

# 部署必填：问答 API 密钥（nginx 注入后端，勿提交 Git）
# 生成：python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_API_KEY=change-me-generate-a-long-random-key

# 安全默认（与 docker-compose.yml 一致）
SECURITY_REQUIRE_API_KEY=true
RATE_LIMIT_ASK_PER_MINUTE=20
SECURITY_SANITIZE_ERRORS=true

# 可选：HTTP Basic Auth（对外暴露整站时建议，需 deploy/htpasswd，见 docs/SECURITY.md）
# NGINX_BASIC_AUTH=on
