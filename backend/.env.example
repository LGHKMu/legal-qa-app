DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_LOCAL_ONLY=true
# 本地 embedding / reranker 推理设备：auto（有 GPU 用 cuda）| cuda | cuda:0 | cpu
INFERENCE_DEVICE=cuda
# 请求 Trace（JSONL 落盘至 data/traces/）
TRACE_ENABLED=true
# TRACE_DIR=./data/traces
# 回答引用校验：生成后检查【法律依据】法条是否在知识库中
CITATION_VERIFY_ENABLED=true
CITATION_VERIFY_REPAIR_ENABLED=true
CHROMA_DIR=./data/chroma
TOP_K=5
QUERY_REWRITE_MODE=two_stage

# BM25 参与 RRF：仅前 N 条、权重 <1（不完全剔除 BM25）
# BM25_RRF_MAX_ENTRIES=5
# BM25_RRF_WEIGHT=0.5

# RERANK_ENABLED=true
# RERANK_MODEL_PATH=./data/models/bge-reranker-base
# RERANK_LOCAL_ONLY=true
# RERANK_MMR_ENABLED=true
# RERANK_MMR_LAMBDA=0.85
# RERANK_MMR_PURE_LEAD=1
# RERANK_GROUP_CLUSTER_THRESHOLD=0.78
# 精排截断：cur>=top×α（始终，min_k 不豁免）；cur>=prev×(1-γ)（仅 min_k 条之后）
RERANK_GAP_TRUNCATE_ENABLED=true
# RERANK_TRUNCATE_MIN_RELATIVE=0.72
# RERANK_TRUNCATE_MAX_STEP_DROP=0.25
# RERANK_GAP_TRUNCATE_MIN=2

# 部署（Docker / 生产）
# CORS_ORIGINS=http://localhost:8080,https://your-domain.com
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=8001
# LOG_LEVEL=info
